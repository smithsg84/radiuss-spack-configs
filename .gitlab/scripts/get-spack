#!/bin/bash

##############################################################################
# Copyright (c) 2022, Lawrence Livermore National Security, LLC and
# RADIUSS project contributors. See the COPYRIGHT file for details.
#
# SPDX-License-Identifier: (MIT)
##############################################################################

set -euo pipefail

# Fetch or reuse the Spack checkout used by CI.
#
# Key points:
# - If ${MY_SPACK_PARENT_DIR}/spack already has tag ${CI_PIPELINE_ID}:
#   - If using ${MY_SPACK_COMMIT}, check if the existing checkout is already at
#     that commit. If not, fix the checkout.
#   - Else assume this pipeline already prepared the checkout and leave all
#     refs unchanged.
# - Without MY_SPACK_COMMIT, MY_SPACK_BRANCH is required. Branch refs can move,
#   for example if a failing job gets retried, so this is not recommended. To
#   Users can use --warn-branch-ref to make this explicit in the CI log. The
#   resolved commit is printed for traceability.

WARN_BRANCH_REF=false

while [[ $# -gt 0 ]]
do
  case "$1" in
    --warn-branch-ref)
      WARN_BRANCH_REF=true
      ;;
    --help)
      echo "Usage: $0 [--warn-branch-ref]"
      exit 0
      ;;
    *)
      echo "Error: unknown option: $1" >&2
      echo "Usage: $0 [--warn-branch-ref]" >&2
      exit 1
      ;;
  esac
  shift
done

hostname

#[get-spack--]
: "${MY_SPACK_PARENT_DIR:?MY_SPACK_PARENT_DIR must be set}"
: "${MY_SPACK_REPO:?MY_SPACK_REPO must be set}"

SPACK_DIR="${MY_SPACK_PARENT_DIR}/spack"

ensure_existing_spack_dir_is_git_repo() {
  if [[ -d "${SPACK_DIR}" && ! -d "${SPACK_DIR}/.git" ]]
  then
    echo "Error: ${SPACK_DIR} exists but is not a git repository." >&2
    exit 1
  fi
}

pipeline_tag_exists() {
  [[ -n "${CI_PIPELINE_ID:-}" ]] &&
    [[ -d "${SPACK_DIR}/.git" ]] &&
    git -C "${SPACK_DIR}" rev-parse --verify --quiet "refs/tags/${CI_PIPELINE_ID}" >/dev/null
}

tag_pipeline_commit() {
  if [[ -n "${CI_PIPELINE_ID:-}" ]]
  then
    if pipeline_tag_exists
    then
      return 0
    fi
    git -C "${SPACK_DIR}" tag "${CI_PIPELINE_ID}"
  fi
}

current_checkout_matches_commit() {
  if [[ ! -d "${SPACK_DIR}/.git" ]]
  then
    return 1
  fi

  local current_commit resolved_commit
  current_commit=$(git -C "${SPACK_DIR}" rev-parse --verify HEAD 2>/dev/null) || return 1
  resolved_commit=$(git -C "${SPACK_DIR}" rev-parse --verify "${MY_SPACK_COMMIT}^{commit}" 2>/dev/null) || return 1
  [[ "${current_commit}" == "${resolved_commit}" ]]
}

ensure_existing_spack_dir_is_git_repo

if pipeline_tag_exists
then
  current_commit=$(git -C "${SPACK_DIR}" rev-parse HEAD)
  tagged_commit=$(git -C "${SPACK_DIR}" rev-list -n 1 "${CI_PIPELINE_ID}")
  echo "Info: Reusing existing Spack checkout for CI pipeline ${CI_PIPELINE_ID}."
  echo "Info: Current Spack HEAD is ${current_commit}; pipeline tag points to ${tagged_commit}."
  if [[ "${current_commit}" != "${tagged_commit}" ]]
  then
    echo "Warning: Checkout wasn't pointing at pipeline tag, fixing..."
    git -C "${SPACK_DIR}" checkout --detach "${tagget_commit}"
    echo "Warning: Fixed!"
  fi
  exit 0
fi

if [[ -n "${MY_SPACK_COMMIT:-}" ]]
then
  if current_checkout_matches_commit
  then
    tag_pipeline_commit
    exit 0
  fi

  if [[ ! -d "${SPACK_DIR}" ]]
  then
    mkdir -p "${MY_SPACK_PARENT_DIR}"
    git init "${SPACK_DIR}"
  fi

  git -C "${SPACK_DIR}" fetch --depth 1 "${MY_SPACK_REPO}" "${MY_SPACK_COMMIT}"
  git -C "${SPACK_DIR}" checkout --detach "${MY_SPACK_COMMIT}"
  tag_pipeline_commit
else
  : "${MY_SPACK_BRANCH:?MY_SPACK_BRANCH must be set when MY_SPACK_COMMIT is not set}"

  if [[ "${WARN_BRANCH_REF}" == true ]]
  then
    echo "Warning: using branch ref '${MY_SPACK_BRANCH}' is not reproducible because the branch may move. Prefer setting MY_SPACK_COMMIT to a full commit hash." >&2
  fi

  if [[ ! -d "${SPACK_DIR}" ]]
  then
    mkdir -p "${MY_SPACK_PARENT_DIR}"
    git clone "${MY_SPACK_REPO}" --depth 1 --branch "${MY_SPACK_BRANCH}" "${SPACK_DIR}"
  elif [[ ! -d "${SPACK_DIR}/.git" ]]
  then
    echo "Error: ${SPACK_DIR} exists but is not a git repository." >&2
    exit 1
  else
    git -C "${SPACK_DIR}" fetch --depth 1 "${MY_SPACK_REPO}" "${MY_SPACK_BRANCH}"
    git -C "${SPACK_DIR}" checkout -B "${MY_SPACK_BRANCH}" FETCH_HEAD
  fi

  resolved_commit=$(git -C "${SPACK_DIR}" rev-parse HEAD)
  echo "Info: Spack branch ref '${MY_SPACK_BRANCH}' resolved to commit ${resolved_commit}."
  tag_pipeline_commit
fi
#[--get-spack]
